# ============================================================================
# RoadSafety_Dar — Environment variable template
# ============================================================================
# Copy to .env and fill in real values.  All providers below have a free
# tier; the project still runs locally with every value left blank.
# Generate a real secret key with:
#     python -c "import secrets; print(secrets.token_urlsafe(60))"
# ============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
DJANGO_ENV=dev                                 # dev | prod
DJANGO_SECRET_KEY=replace-with-50-random-chars
DEBUG=True                                     # must be False in prod
ALLOWED_HOSTS=localhost,127.0.0.1              # comma-separated, no spaces
SITE_URL=http://localhost:8000                  # used for email link generation

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local dev (zero-config, works out of the box):
DATABASE_URL=sqlite:///db.sqlite3
# Production with spatial queries:
# DATABASE_URL=postgis://roadsafety:password@localhost:5432/roadsafety

# ---------------------------------------------------------------------------
# Supabase & Google OAuth Configuration
# ---------------------------------------------------------------------------
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth Redirect URLs
LOGIN_REDIRECT_URL=/dashboard/
LOGOUT_REDIRECT_URL=/

# ---------------------------------------------------------------------------
# AI providers — multi-provider fallback chain
# (Used by Prompt 12: AI Summarizer. App still works without any of these.)
# ---------------------------------------------------------------------------
# Primary: Groq (free, ~30 req/min, Llama 3.3 70B)
# Sign up: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_BASE=https://api.groq.com/openai/v1

# Fallback 1: Cloudflare Workers AI (free, 10k neurons/day)
# Sign up: https://dash.cloudflare.com -> Workers -> AI
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Fallback 2: Google Gemini 2.5 Flash (free, 15 req/min)
# Sign up: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Legacy v1.1: OpenRouter (kept for backward compat with existing code paths)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-m3

# ---------------------------------------------------------------------------
# Media storage — Cloudinary (free tier: 25 GB, 25k transforms/mo)
# (Used by Prompt 3: Public Report Flow v2 with photo / video evidence.)
# Sign up: https://cloudinary.com
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional single-line alternative (cloudinary://key:secret@cloud_name)
CLOUDINARY_URL=

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
# Telegram bot (free; used by Prompt 9: Notifications)
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Resend transactional email (free tier: 3k emails/mo)
# Sign up: https://resend.com
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@roadsafety.local

# Africa's Talking SMS (pay-per-SMS, ~$0.01/SMS in Tanzania, free sandbox)
# Sign up: https://africastalking.com
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=RoadSafety

# ---------------------------------------------------------------------------
# Anti-spam — Cloudflare Turnstile (free, privacy-respecting CAPTCHA)
# (Used by Prompt 3: Public Report Flow v2.)
# Sign up: https://dash.cloudflare.com -> Turnstile
# ---------------------------------------------------------------------------
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Cache + background jobs — Upstash Redis (free: 10k commands/day)
# (Used by Prompt 14: Performance & Production Hardening.)
# Sign up: https://upstash.com
# ---------------------------------------------------------------------------
UPSTASH_REDIS_URL=
REDIS_URL=

# ---------------------------------------------------------------------------
# Monitoring — Sentry (free: 5k events/mo)
# (Wired up in prod.py — no-op if DSN is blank.)
# Sign up: https://sentry.io
# ---------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Optional: Git commit SHA for Sentry release tracking (set automatically
# by Railway / Render / Fly.io deploys).
# ---------------------------------------------------------------------------
# GIT_COMMIT_SHA=
