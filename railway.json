# Railway deployment configuration
# See: https://docs.railway.app/guides/django

build:
  builder: NIXPACKS

deploy:
  startCommand: "python manage.py migrate && python manage.py collectstatic --noinput && gunicorn roadsafety.wsgi"
  healthcheckPath: /dashboard/
  healthcheckTimeout: 60
  restartPolicyType: ON_FAILURE
  restartPolicyMaxRetries: 3
